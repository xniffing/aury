(module strdemo (fn greet (params (n i64)) (ret str) (body (call str.concat (call i64.to_str (ref n)) (lit !)))) (fn parse-double (params (s str)) (ret i64) (body (call i64.mul (cast i64 (ref s)) (lit 2)))) (fn concat3 (params (a str) (b str) (c str)) (ret str) (body (call str.concat (call str.concat (ref a) (ref b)) (ref c)))) (fn is-yes (params (s str)) (ret bool) (body (call str.eq (ref s) (lit yes)))) (fn length (params (s str)) (ret i64) (body (call str.len (ref s)))) (fn describe (params (n i64)) (ret str) (body (if (call i64.gt (ref n) (lit 0)) (then (call str.concat (lit pos:) (call i64.to_str (ref n)))) (else (lit nonpos))))))