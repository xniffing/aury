(module math
  (struct Vec2 (x i64) (y i64))

  (fn gcd (params (a i64) (b i64)) (ret i64)
    (body
      (if (call i64.eq (ref b) (lit 0)) (then (call i64.abs (ref a))) (else (call gcd (ref b) (call i64.mod (call i64.abs (ref a)) (ref b)))))))

  (fn lcm (params (a i64) (b i64)) (ret i64)
    (body
      (if (call bool.or (call i64.eq (ref a) (lit 0)) (call i64.eq (ref b) (lit 0))) (then (lit 0))
        (else
          (call i64.div (call i64.mul (call i64.abs (ref a)) (call i64.abs (ref b))) (call gcd (ref a) (ref b)))))))

  (fn is-prime (params (n i64)) (ret bool)
    (body (if (call i64.lt (ref n) (lit 2)) (then false) (else (call prime-step (ref n) (lit 2))))))

  (fn prime-step (params (n i64) (d i64)) (ret bool)
    (body
      (if (call i64.gt (call i64.mul (ref d) (ref d)) (ref n)) (then true)
        (else
          (if (call i64.eq (call i64.mod (ref n) (ref d)) (lit 0)) (then false) (else (call prime-step (ref n) (call i64.add (ref d) (lit 1)))))))))

  (fn pow-mod (params (base i64) (exp i64) (m i64)) (ret i64)
    (body
      (if (call i64.eq (ref exp) (lit 0)) (then (lit 1))
        (else
          (if (call i64.eq (call i64.mod (ref exp) (lit 2)) (lit 0))
            (then
              (let h i64 (call pow-mod (ref base) (call i64.div (ref exp) (lit 2)) (ref m)) (call i64.mod (call i64.mul (ref h) (ref h)) (ref m))))
            (else
              (call i64.mod
                (call i64.mul (ref base) (call pow-mod (ref base) (call i64.sub (ref exp) (lit 1)) (ref m))) (ref m))))))))

  (fn fib (params (n i64)) (ret i64) (body (call fib-acc (lit 0) (lit 1) (ref n))))

  (fn fib-acc (params (a i64) (b i64) (n i64)) (ret i64)
    (body
      (if (call i64.eq (ref n) (lit 0)) (then (ref a))
        (else (call fib-acc (ref b) (call i64.add (ref a) (ref b)) (call i64.sub (ref n) (lit 1)))))))

  (fn fact (params (n i64)) (ret i64)
    (body
      (match (ref n) ((lit 0) (lit 1)) (_ (call i64.mul (ref n) (call fact (call i64.sub (ref n) (lit 1))))))))

  (fn isqrt (params (n i64)) (ret i64) (body (call isqrt-search (lit 0) (call i64.add (ref n) (lit 1)) (ref n))))

  (fn isqrt-search (params (lo i64) (hi i64) (n i64)) (ret i64)
    (body
      (if (call i64.ge (ref lo) (ref hi)) (then (call i64.sub (ref lo) (lit 1)))
        (else
          (let mid i64 (call i64.div (call i64.add (ref lo) (ref hi)) (lit 2))
            (if (call i64.le (call i64.mul (ref mid) (ref mid)) (ref n)) (then (call isqrt-search (call i64.add (ref mid) (lit 1)) (ref hi) (ref n))) (else (call isqrt-search (ref lo) (ref mid) (ref n)))))))))

  (fn digit-sum (params (n i64)) (ret i64)
    (body
      (let m i64 (call i64.abs (ref n))
        (if (call i64.eq (ref m) (lit 0)) (then (lit 0))
          (else
            (call i64.add (call i64.mod (ref m) (lit 10)) (call digit-sum (call i64.div (ref m) (lit 10)))))))))

  (fn collatz (params (n i64)) (ret i64) (body (call collatz-step (ref n) (lit 0))))

  (fn collatz-step (params (n i64) (steps i64)) (ret i64)
    (body
      (if (call i64.eq (ref n) (lit 1)) (then (ref steps))
        (else
          (if (call i64.eq (call i64.mod (ref n) (lit 2)) (lit 0))
            (then
              (call collatz-step (call i64.div (ref n) (lit 2)) (call i64.add (ref steps) (lit 1))))
            (else
              (call collatz-step (call i64.add (call i64.mul (ref n) (lit 3)) (lit 1)) (call i64.add (ref steps) (lit 1)))))))))

  (fn poly-eval (params (c (vec i64)) (x i64) (i i64)) (ret i64)
    (body
      (if (call i64.ge (ref i) (len (ref c))) (then (lit 0))
        (else
          (call i64.add (idx (ref c) (ref i))
            (call i64.mul (ref x) (call poly-eval (ref c) (ref x) (call i64.add (ref i) (lit 1)))))))))

  (fn v2add (params (p (struct Vec2)) (q (struct Vec2))) (ret (struct Vec2))
    (body
      (new-struct Vec2 (x (call i64.add (get (ref p) x) (get (ref q) x))) (y (call i64.add (get (ref p) y) (get (ref q) y))))))

  (fn v2dot (params (p (struct Vec2)) (q (struct Vec2))) (ret i64)
    (body
      (call i64.add (call i64.mul (get (ref p) x) (get (ref q) x)) (call i64.mul (get (ref p) y) (get (ref q) y)))))

  (fn v2scale (params (p (struct Vec2)) (k i64)) (ret (struct Vec2))
    (body
      (new-struct Vec2 (x (call i64.mul (get (ref p) x) (ref k))) (y (call i64.mul (get (ref p) y) (ref k))))))

  (fn v2manhattan (params (p (struct Vec2))) (ret i64) (body (call i64.add (call i64.abs (get (ref p) x)) (call i64.abs (get (ref p) y)))))

  (fn describe-mul (params (a i64) (b i64)) (ret str)
    (body
      (let p i64 (call i64.mul (ref a) (ref b))
        (call str.concat (call str.concat (call i64.to_str (ref a)) (lit "*"))
          (call str.concat (call i64.to_str (ref b)) (call str.concat (lit "=") (call i64.to_str (ref p))))))))

  (fn cast-roundtrip (params (n i64)) (ret i64) (body (cast i64 (call i64.to_str (ref n)))))

  (fn rand-even (params) (ret i64) (effects rng)
    (body
      (region r
        (loop
          (let r1 i64 (call rng.next)
            (if (call i64.eq (call i64.mod (ref r1) (lit 2)) (lit 0)) (then (return (ref r1))) (else (lit 0))))))))

  (spec
    (property gcd-commutative
      (forall ((a i64) (b i64))
        (if (call bool.and (call i64.gt (ref a) (lit 0)) (call i64.gt (ref b) (lit 0))) (then (call i64.eq (call gcd (ref a) (ref b)) (call gcd (ref b) (ref a)))) (else true))))
    (property gcd-divides
      (forall ((a i64) (b i64))
        (if (call bool.and (call i64.gt (ref a) (lit 0)) (call i64.gt (ref b) (lit 0)))
          (then
            (call bool.and (call i64.eq (call i64.mod (ref a) (call gcd (ref a) (ref b))) (lit 0)) (call i64.eq (call i64.mod (ref b) (call gcd (ref a) (ref b))) (lit 0)))) (else true))))
    (property lcm-gcd-product
      (forall ((a i64) (b i64))
        (if (call bool.and (call i64.gt (ref a) (lit 0)) (call i64.gt (ref b) (lit 0)))
          (then
            (call i64.eq (call i64.mul (call lcm (ref a) (ref b)) (call gcd (ref a) (ref b))) (call i64.mul (ref a) (ref b)))) (else true))))
    (property prime-no-divisor
      (forall ((p i64) (d i64))
        (if
          (call bool.and (call i64.ge (ref p) (lit 2)) (call bool.and (call i64.ge (ref d) (lit 2)) (call i64.lt (ref d) (ref p))))
          (then
            (if (call is-prime (ref p)) (then (call i64.neq (call i64.mod (ref p) (ref d)) (lit 0))) (else true))) (else true))))
    (property pow-mod-zero
      (forall ((base i64) (m i64))
        (if (call i64.gt (ref m) (lit 1)) (then (call i64.eq (call pow-mod (ref base) (lit 0) (ref m)) (lit 1))) (else true))))
    (property fib-recurrence
      (forall ((n i64))
        (if (call bool.and (call i64.ge (ref n) (lit 0)) (call i64.le (ref n) (lit 30)))
          (then
            (call i64.eq (call fib (call i64.add (ref n) (lit 2))) (call i64.add (call fib (call i64.add (ref n) (lit 1))) (call fib (ref n))))) (else true))))
    (property fact-recurrence
      (forall ((n i64))
        (if (call bool.and (call i64.ge (ref n) (lit 1)) (call i64.le (ref n) (lit 18)))
          (then
            (call i64.eq (call fact (ref n)) (call i64.mul (ref n) (call fact (call i64.sub (ref n) (lit 1)))))) (else true))))
    (property isqrt-bounded
      (forall ((n i64))
        (if (call bool.and (call i64.ge (ref n) (lit 0)) (call i64.le (ref n) (lit 1000)))
          (then
            (let r i64 (call isqrt (ref n))
              (call bool.and (call i64.le (call i64.mul (ref r) (ref r)) (ref n))
                (call i64.lt (ref n) (call i64.mul (call i64.add (ref r) (lit 1)) (call i64.add (ref r) (lit 1))))))) (else true))))
    (property digit-sum-shift
      (forall ((n i64))
        (if (call bool.and (call i64.ge (ref n) (lit 0)) (call i64.le (ref n) (lit 100)))
          (then
            (call i64.eq (call digit-sum (call i64.mul (ref n) (lit 10))) (call digit-sum (ref n)))) (else true))))
    (property cast-roundtrip-prop
      (forall ((n i64))
        (if (call bool.and (call i64.ge (ref n) (lit 0)) (call i64.le (ref n) (lit 1000))) (then (call i64.eq (call cast-roundtrip (ref n)) (ref n))) (else true))))
    (property poly-constant
      (forall ((x i64) (c i64)) (call i64.eq (call poly-eval (vec-new (vec i64) (ref c)) (ref x) (lit 0)) (ref c))))
    (property v2add-x
      (forall ((a i64) (b i64) (c i64) (d i64))
        (call i64.eq
          (get
            (call v2add (new-struct Vec2 (x (ref a)) (y (ref b))) (new-struct Vec2 (x (ref c)) (y (ref d)))) x) (call i64.add (ref a) (ref c)))))
    (property v2dot-symmetric
      (forall ((a i64) (b i64) (c i64) (d i64))
        (call i64.eq
          (call v2dot (new-struct Vec2 (x (ref a)) (y (ref b))) (new-struct Vec2 (x (ref c)) (y (ref d))))
          (call v2dot (new-struct Vec2 (x (ref c)) (y (ref d))) (new-struct Vec2 (x (ref a)) (y (ref b)))))))
    (property v2manhattan-nonneg
      (forall ((a i64) (b i64)) (call i64.ge (call v2manhattan (new-struct Vec2 (x (ref a)) (y (ref b)))) (lit 0))))
    (property collatz-terminates
      (forall ((n i64))
        (if (call bool.and (call i64.ge (ref n) (lit 1)) (call i64.le (ref n) (lit 50))) (then (call i64.ge (call collatz (ref n)) (lit 0))) (else true))))
  )
)
