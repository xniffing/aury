(module native-parity
  (struct Packet (name str) (values (vec i64)) (nested (vec (vec bool))))
  (fn vec-id (params (xs (vec i64))) (ret (vec i64))
    (body (ref xs)))
  (fn vec-at (params (xs (vec str)) (i i64)) (ret str)
    (body (idx (ref xs) (ref i))))
  (fn vec-size (params (xs (vec (vec i64)))) (ret i64)
    (body (call i64.add (len (ref xs)) (len (idx (ref xs) (lit 0))))))
  (fn vec-sum-from (params (xs (vec i64)) (i i64)) (ret i64)
    (body (if (call i64.ge (ref i) (len (ref xs)))
      (then (lit 0))
      (else (call i64.add (idx (ref xs) (ref i))
        (call vec-sum-from (ref xs) (call i64.add (ref i) (lit 1))))))))
  (fn empty (params) (ret (vec (vec i64)))
    (body (vec-new (vec (vec i64)))))
  (fn packet-id (params (p (struct Packet))) (ret (struct Packet))
    (body (ref p)))
  (fn packet-name (params (p (struct Packet))) (ret str)
    (body (get (ref p) name)))
  (fn branch-vector (params (early bool)) (ret (vec i64))
    (body (vec-new (vec i64)
      (if (ref early)
        (then (return (vec-new (vec i64) (lit 9))))
        (else (lit 1)))
      (lit 2))))
  (fn branch-packet (params (early bool)) (ret (struct Packet))
    (body (new-struct Packet
      (name (if (ref early)
        (then (return (new-struct Packet
          (name (lit "early"))
          (values (vec-new (vec i64)))
          (nested (vec-new (vec (vec bool)))))))
        (else (lit "late"))))
      (values (vec-new (vec i64) (lit 4)))
      (nested (vec-new (vec (vec bool)))))))
  (fn made (params) (ret (struct Packet))
    (body (new-struct Packet
      (nested (vec-new (vec (vec bool)) (vec-new (vec bool) (lit true) (lit false))))
      (name (lit "native"))
      (values (vec-new (vec i64) (lit 3) (lit 4))))))
  (fn copied (params) (ret (vec i64))
    (body (region r (copy (vec-new (vec i64) (lit 7) (lit 8))))))
  (fn random-pair (params) (ret (vec i64)) (effects (rng))
    (body (vec-new (vec i64) (call rng.next) (call helper-rng))))
  (fn helper-rng (params) (ret i64) (effects (rng))
    (body (call rng.i64)))
  (fn result-id (params (r (result (vec i64) (struct Packet))))
    (ret (result (vec i64) (struct Packet))) (body (ref r)))
  (fn unit-value (params) (ret unit) (body unit))
  (fn parse-value (params (s str)) (ret (result i64 str))
    (body (call i64.parse (ref s))))
  (fn edge-div (params) (ret i64)
    (body (call i64.div (lit -9223372036854775808) (lit -1))))
  (fn edge-mod (params) (ret i64)
    (body (call i64.mod (lit -9223372036854775808) (lit -1))))
  (fn edge-neg (params) (ret i64)
    (body (call i64.neg (lit -9223372036854775808))))
  (fn edge-abs (params) (ret i64)
    (body (call i64.abs (lit -9223372036854775808))))
  (fn nested-return (params) (ret i64)
    (body (block (return (lit 9)) (lit 100))))
)
