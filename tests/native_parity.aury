(module native-parity
  (struct Packet (name str) (values (vec i64)) (nested (vec (vec bool))))
  (fn vec-id (params (xs (vec i64))) (ret (vec i64))
    (body (ref xs)))
  (fn vec-at (params (xs (vec str)) (i i64)) (ret str)
    (body (idx (ref xs) (ref i))))
  (fn vec-size (params (xs (vec (vec i64)))) (ret i64)
    (body (call i64.add (len (ref xs)) (len (idx (ref xs) (lit 0))))))
  (fn vec-sum-from (params (xs (vec i64)) (i i64)) (ret i64)
    (body (if (call i64.ge (ref i) (len (ref xs)))
      (then (lit 0))
      (else (call i64.add (idx (ref xs) (ref i))
        (call vec-sum-from (ref xs) (call i64.add (ref i) (lit 1))))))))
  (fn empty (params) (ret (vec (vec i64)))
    (body (vec-new (vec (vec i64)))))
  (fn packet-id (params (p (struct Packet))) (ret (struct Packet))
    (body (ref p)))
  (fn packet-name (params (p (struct Packet))) (ret str)
    (body (get (ref p) name)))
  (fn branch-vector (params (early bool)) (ret (vec i64))
    (body (vec-new (vec i64)
      (if (ref early)
        (then (return (vec-new (vec i64) (lit 9))))
        (else (lit 1)))
      (lit 2))))
  (fn branch-packet (params (early bool)) (ret (struct Packet))
    (body (new-struct Packet
      (name (if (ref early)
        (then (return (new-struct Packet
          (name (lit "early"))
          (values (vec-new (vec i64)))
          (nested (vec-new (vec (vec bool)))))))
        (else (lit "late"))))
      (values (vec-new (vec i64) (lit 4)))
      (nested (vec-new (vec (vec bool)))))))
  (fn made (params) (ret (struct Packet))
    (body (new-struct Packet
      (nested (vec-new (vec (vec bool)) (vec-new (vec bool) (lit true) (lit false))))
      (name (lit "native"))
      (values (vec-new (vec i64) (lit 3) (lit 4))))))
  (fn copied (params) (ret (vec i64))
    (body (region r (copy (vec-new (vec i64) (lit 7) (lit 8))))))
  (fn random-pair (params) (ret (vec i64)) (effects (rng))
    (body (vec-new (vec i64) (call rng.next) (call helper-rng))))
  (fn helper-rng (params) (ret i64) (effects (rng))
    (body (call rng.i64)))
  (fn result-id (params (r (result (vec i64) (struct Packet))))
    (ret (result (vec i64) (struct Packet))) (body (ref r)))
  (fn unit-value (params) (ret unit) (body unit))
  (fn parse-value (params (s str)) (ret (result i64 str))
    (body (call i64.parse (ref s))))
  (fn edge-div (params) (ret i64)
    (body (call i64.div (lit -9223372036854775808) (lit -1))))
  (fn edge-mod (params) (ret i64)
    (body (call i64.mod (lit -9223372036854775808) (lit -1))))
  (fn edge-neg (params) (ret i64)
    (body (call i64.neg (lit -9223372036854775808))))
  (fn edge-abs (params) (ret i64)
    (body (call i64.abs (lit -9223372036854775808))))
  (fn nested-return (params) (ret i64)
    (body (block (return (lit 9)) (lit 100))))
  ; --- Track 2: mutable loops / accumulators ---
  ; iterative factorial: mutable accumulator + counter, exit via (break acc)
  (fn loop-fact (params (n i64)) (ret i64)
    (body
      (let acc i64 1
        (let i i64 1
          (loop
            (if (call i64.gt (ref i) (ref n))
                (break (ref acc))
                (block
                  (set acc (call i64.mul (ref acc) (ref i)))
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; iterative countdown sum 1..n
  (fn loop-sum (params (n i64)) (ret i64)
    (body
      (let acc i64 0
        (let i i64 (ref n)
          (loop
            (if (call i64.le (ref i) (lit 0))
                (break (ref acc))
                (block
                  (set acc (call i64.add (ref acc) (ref i)))
                  (set i (call i64.sub (ref i) (lit 1)))
                  unit)))))))
  ; nested loops: sum over the i*j multiplication table up to n (inner
  ; loop breaks with unit, exercising a value-less break + carried state)
  (fn loop-table (params (n i64)) (ret i64)
    (body
      (let total i64 0
        (let i i64 1
          (loop
            (if (call i64.gt (ref i) (ref n))
                (break (ref total))
                (block
                  (let j i64 1
                    (loop
                      (if (call i64.gt (ref j) (ref n))
                          (break unit)
                          (block
                            (set total (call i64.add (ref total) (call i64.mul (ref i) (ref j))))
                            (set j (call i64.add (ref j) (lit 1)))
                            unit))))
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; loop that breaks immediately on the first iteration (edge: acc untouched)
  (fn loop-empty (params (n i64)) (ret i64)
    (body
      (let acc i64 42
        (loop (break (ref acc))))))
  ; --- Track 3: f64 floats ---
  ; basic IEEE arithmetic and a returned scalar double
  (fn f-poly (params (x f64)) (ret f64)
    (body (call f64.add
      (call f64.mul (ref x) (call f64.add (ref x) 1.5))
      (call f64.neg 2.25))))
  (fn f-abs (params (x f64)) (ret f64) (body (call f64.abs (ref x))))
  ; div-by-zero is IEEE: never traps — returns +inf / -inf / NaN
  (fn f-inf (params) (ret f64) (body (call f64.div 1.0 0.0)))
  (fn f-ninf (params) (ret f64) (body (call f64.div -1.0 0.0)))
  (fn f-nan (params) (ret f64) (body (call f64.div 0.0 0.0)))
  ; NaN compares unequal to everything, including itself
  (fn f-nan-self-eq (params) (ret bool)
    (body (let n f64 (call f64.div 0.0 0.0) (call f64.eq (ref n) (ref n)))))
  (fn f-cmp (params (a f64) (b f64)) (ret bool) (body (call f64.lt (ref a) (ref b))))
  (fn f-to-str (params (x f64)) (ret str) (body (call f64.to_str (ref x))))
  ; numeric casts both directions (f->i saturates/truncates toward zero)
  (fn f-of-i (params (n i64)) (ret f64) (body (cast f64 (ref n))))
  (fn i-of-f (params (x f64)) (ret i64) (body (cast i64 (ref x))))
  ; f64 flowing through an aggregate slot (vec) then reduced: mean of a vec
  (fn f-mean-from (params (xs (vec f64)) (i i64) (acc f64)) (ret f64)
    (body (if (call i64.ge (ref i) (len (ref xs)))
      (then (ref acc))
      (else (call f-mean-from (ref xs)
        (call i64.add (ref i) (lit 1))
        (call f64.add (ref acc) (idx (ref xs) (ref i))))))))
  (fn f-mean (params (xs (vec f64))) (ret f64)
    (body (call f64.div
      (call f-mean-from (ref xs) (lit 0) 0.0)
      (cast f64 (len (ref xs))))))
  ; f64 as a struct field, round-tripped through boxing
  (fn f-point-x (params (p (struct FPoint))) (ret f64) (body (get (ref p) x)))
  (fn f-make-point (params (a f64) (b f64)) (ret (struct FPoint))
    (body (new-struct FPoint (x (ref a)) (y (ref b)))))
  (struct FPoint (x f64) (y f64))
  ; --- v0.2 Track B: growable vecs via vec-push (loop-carried accumulator) ---
  ; build [0*0, 1*1, ...) up to n by appending in a mutable loop
  (fn vp-build (params (n i64)) (ret (vec i64))
    (body
      (let acc (vec i64) (vec-new (vec i64))
        (let i i64 0
          (loop
            (if (call i64.ge (ref i) (ref n))
                (break (ref acc))
                (block
                  (set acc (vec-push (ref acc) (call i64.mul (ref i) (ref i))))
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; map: double every element into a fresh vec
  (fn vp-map-double (params (xs (vec i64))) (ret (vec i64))
    (body
      (let out (vec i64) (vec-new (vec i64))
        (let i i64 0
          (loop
            (if (call i64.ge (ref i) (len (ref xs)))
                (break (ref out))
                (block
                  (set out (vec-push (ref out) (call i64.mul (idx (ref xs) (ref i)) (lit 2))))
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; filter: keep even elements
  (fn vp-filter-even (params (xs (vec i64))) (ret (vec i64))
    (body
      (let out (vec i64) (vec-new (vec i64))
        (let i i64 0
          (loop
            (if (call i64.ge (ref i) (len (ref xs)))
                (break (ref out))
                (block
                  (if (call i64.eq (call i64.mod (idx (ref xs) (ref i)) (lit 2)) (lit 0))
                      (set out (vec-push (ref out) (idx (ref xs) (ref i))))
                      unit)
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; reduce: sum via idx/len (borrows the built vec)
  (fn vp-reduce-sum (params (xs (vec i64))) (ret i64)
    (body
      (let acc i64 0
        (let i i64 0
          (loop
            (if (call i64.ge (ref i) (len (ref xs)))
                (break (ref acc))
                (block
                  (set acc (call i64.add (ref acc) (idx (ref xs) (ref i))))
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; round-trip: build then reduce
  (fn vp-build-sum (params (n i64)) (ret i64)
    (body (call vp-reduce-sum (vp-build (ref n)))))
  ; f64 growable vec: scale every element by 1.5 into a fresh vec
  (fn vp-fscale (params (xs (vec f64))) (ret (vec f64))
    (body
      (let out (vec f64) (vec-new (vec f64))
        (let i i64 0
          (loop
            (if (call i64.ge (ref i) (len (ref xs)))
                (break (ref out))
                (block
                  (set out (vec-push (ref out) (call f64.mul (idx (ref xs) (ref i)) 1.5)))
                  (set i (call i64.add (ref i) (lit 1)))
                  unit)))))))
  ; use-after-move repaired by inserting copy: push twice off one source
  (fn vp-copy-branch (params (n i64)) (ret i64)
    (body
      (let base (vec i64) (vp-build (ref n))
        (let a (vec i64) (vec-push (copy base) (lit 100))
          (let b (vec i64) (vec-push (copy base) (lit 200))
            (call i64.add (len (ref a)) (len (ref b))))))))
  ; --- v0.2 Track C1b: arena-managed region (scalar result, no escape) ---
  ; builds a scratch vector inside a region and reduces it to a scalar; the
  ; region frees the scratch at exit. The observable result is unchanged.
  (fn region-scalar (params (n i64)) (ret i64)
    (body
      (region r
        (call i64.add
          (len (vec-new (vec i64) (ref n) (ref n) (ref n)))
          (ref n)))))
  ; loop/accumulator region: build a vector with set+vec-push inside a region and
  ; break it out. Only in-region bindings/loops are touched, so the region is
  ; arena-managed — every intermediate vector is freed and the result relocated.
  (fn region-build (params (n i64)) (ret (vec i64))
    (body
      (region r
        (let acc (vec i64) (vec-new (vec i64))
          (let i i64 0
            (loop
              (if (call i64.ge (ref i) (ref n))
                  (break (ref acc))
                  (block
                    (set acc (vec-push (ref acc) (call i64.mul (ref i) (ref i))))
                    (set i (call i64.add (ref i) (lit 1)))
                    unit))))))))
  ; early return of an aggregate out of an arena region: the return path unwinds
  ; the region (relocate + free) just like the normal tail does.
  (fn region-early (params (n i64)) (ret (vec i64))
    (body
      (region r
        (block
          (if (call i64.gt (ref n) (lit 0))
              (return (vec-new (vec i64) (ref n) (ref n)))
              unit)
          (vec-new (vec i64) (lit 0))))))
)
